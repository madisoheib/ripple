[server]
host = "0.0.0.0"
port = 8080

[[apps]]
id = "app1"
key = "resonance-key"
secret = "resonance-secret"
max_connections = 0        # 0 = unlimited
# webhook_url = "https://your-app.com/pusher/webhooks"   # channel_occupied/vacated, member_added/removed

[limits]
max_message_size_kb = 10
activity_timeout_s = 120
max_channels_per_connection = 100
# Browser origins allowed to connect. Empty = allow all (dev only!).
# Production: allowed_origins = ["https://app.example.com"]
allowed_origins = []
