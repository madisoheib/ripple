[server]
host = "0.0.0.0"
port = 8080
# Graceful shutdown: on SIGTERM/SIGINT, stop accepting, send 1001 close
# frames to all clients (after flushing in-flight messages), drain up to:
shutdown_timeout_s = 30

# Native TLS — omit this table to serve plain ws/http (terminate at your proxy).
# [tls]
# cert = "/path/fullchain.pem"
# key = "/path/privkey.pem"

[[apps]]
id = "app1"
key = "ripple-key"
secret = "ripple-secret"
max_connections = 0        # 0 = unlimited
# webhook_url = "https://your-app.com/pusher/webhooks"   # channel_occupied/vacated, member_added/removed

# Multi-tenant fairness (all default 0 = unlimited):
# max_messages_per_second = 1000   # REST publish quota -> 429 beyond
# max_channels = 10000             # live channels for this app
# max_presence_members = 100       # unique users per presence channel

# Session-resume extension (opt-in, Pusher-compatible): keep the last N
# events per channel; reconnecting clients replay what they missed with
# {event:"ripple:resume", data:{channel, last_seq}}.
# history_size = 100

[limits]
max_message_size_kb = 10
activity_timeout_s = 120
max_channels_per_connection = 100
# Browser origins allowed to connect. Empty = allow all (dev only!).
# Production: allowed_origins = ["https://app.example.com"]
allowed_origins = []
